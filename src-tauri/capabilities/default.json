{
  "$schema": "../node_modules/@tauri-apps/cli/schema/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Project Estimator",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-app-data-read-recursive",
    "fs:allow-app-data-write-recursive",
    "fs:default"
  ]
}
